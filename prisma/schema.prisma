generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  provider  String   @default("credentials")
  createdAt DateTime @default(now())

  exchangeKeys   ExchangeApiKey[]
  paperWallet    PaperWallet?
  paperPositions PaperPosition[]
  paperOrders    PaperOrder[]
  paperTrades    PaperTrade[]
  telegramLinks  TelegramUserLink[]
  paperAccount   PaperAccount?
  tradeLogs      TradeLog[]
  aiDecisionLogs AiDecisionLog[]
  tradingPreference TradingPreference?
}

model TelegramUserLink {
  id             String @id @default(cuid())
  telegramChatId String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, telegramChatId])
}

model ExchangeApiKey {
  id        String @id @default(cuid())
  exchange  String
  apiKey    String
  secretKey String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, exchange])
}

model PaperWallet {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency String @default("USDT")
  cash     Float  @default(10000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaperPosition {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  exchange String @default("binance")
  symbol   String

  qty       Float
  avgPrice  Float
  invested  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, exchange, symbol])
}

model PaperOrder {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  exchange String @default("binance")
  symbol   String
  side     String
  type     String @default("MARKET")
  status   String @default("FILLED")

  price  Float
  qty    Float
  amount Float

  createdAt DateTime @default(now())
}

model PaperTrade {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId String?

  exchange String @default("binance")
  symbol   String
  side     String

  price Float
  qty   Float
  value Float
  pnl   Float?

  createdAt DateTime @default(now())
}

model TradingPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode String @default("PAPER")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trading_preferences")
}

model PaperAccount {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  virtualBalance Float @default(10000000)
  virtualPnl     Float @default(0)

  updatedAt DateTime @updatedAt

  @@map("paper_accounts")
}

model TradeLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode        String
  market      String
  side        String
  signal      String?
  probability Float?
  price       Float?
  entryPrice  Float?
  exitPrice   Float?
  pnl         Float?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("trade_logs")
}

model AiDecisionLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  market           String
  rsi              Float?
  volume           Float?
  trendProbability Float?
  confidence       Float?
  finalDecision    String
  mode             String @default("PAPER")

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("ai_decision_logs")
}
